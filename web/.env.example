# ==============================================================================
# Biến môi trường web (Next.js) — Copy thành `.env.local` và điền giá trị thật.
# KHÔNG commit file `.env.local` lên git!
# ==============================================================================

# --- Supabase (public — dùng được phía client/browser) ---
# Project URL (Supabase -> Project Settings -> Data API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
# Anon/publishable key (Project Settings -> API Keys -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Supabase (secret — CHỈ dùng phía server, KHÔNG đặt NEXT_PUBLIC_) ---
# Service Role key — bypass RLS, dùng cho API routes server-side.
# GIỮ TUYỆT MẬT: không dùng anon key, không để lộ ra client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Host API công khai của bot (profile/leaderboard/stats/event) ---
# Mặc định trỏ tới host hiện tại; đổi nếu deploy bot ở domain khác.
NEXT_PUBLIC_BOT_API=https://waguribot.wispbyte.app

# --- Quyền admin web ---
# Discord ID của owner, ngăn cách bằng dấu phẩy — dùng cho trang duyệt đơn Premium.
OWNER_IDS=your_discord_user_id

# --- VietQR / Thanh toán Premium ---
# Số tài khoản VietQR hiển thị khi người dùng mua Premium.
VCB_ACCOUNT=your_vcb_account_number
# Mã ngân hàng VietQR (ví dụ: VCB, TCB, MB...).
VCB_BANK=VCB
# Tên chủ tài khoản (hiển thị trên trang mua Premium).
VCB_HOLDER=HO TEN CHU TAI KHOAN
