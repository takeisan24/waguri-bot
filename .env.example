# ==============================================================================
# Biến môi trường — Copy file này thành `.env` và điền giá trị thật.
# KHÔNG commit file `.env` lên git!
# ==============================================================================

# --- Discord ---
# Bot Token (Developer Portal -> app của bạn -> Bot -> Reset Token -> Copy)
DISCORD_TOKEN=your_bot_token_here
# Application ID (Developer Portal -> General Information -> Application ID)
CLIENT_ID=your_application_id_here

# (TÙY CHỌN — chỉ dùng khi DEV) ID server test để đăng ký lệnh TỨC THÌ.
# Để TRỐNG ở production -> lệnh sẽ đăng ký global.
GUILD_ID=

# Discord ID của owner (cho /eco-admin). Nhiều owner: ngăn cách bằng dấu phẩy.
OWNER_IDS=your_discord_user_id

# --- Supabase ---
# Project URL (Supabase -> Project Settings -> Data API -> Project URL)
SUPABASE_URL=https://your_project_ref.supabase.co
# Service Role key (Project Settings -> API Keys -> service_role).
# Bypass RLS cho bot server-side -> GIỮ TUYỆT MẬT, không dùng anon key.
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- AI persona Waguri (tùy chọn) ---
AI_PROVIDER=gemini
# API key Gemini (LẤY FREE tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash
# Muốn đổi sang Claude: đặt AI_PROVIDER=claude + ANTHROPIC_API_KEY + chạy `npm i @anthropic-ai/sdk`
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Top.gg (tùy chọn — chỉ cần sau khi đã list bot trên top.gg) ---
# Token để autopost số server + check vote cho /vote (Top.gg -> bot của bạn -> Webhooks/API).
# Để TRỐNG thì /vote chỉ hiện link, không tự phát thưởng; autopost bị bỏ qua.
# TOPGG_TOKEN=your_topgg_token_here
