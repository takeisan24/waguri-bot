# ==============================================================================
# Choco - Discord Economy & RPG Bot Environment Variables Template
# Copy this file to a new file named `.env` and fill in your credentials.
# Do NOT commit your actual `.env` file to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Discord Bot Configuration
# ------------------------------------------------------------------------------
# Your Discord Bot Token (Get this from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord Application/Client ID (Optional)
# If not provided, the bot will attempt to extract it automatically from the token.
CLIENT_ID=your_discord_client_id_here

# ------------------------------------------------------------------------------
# 2. Supabase Database Configuration
# ------------------------------------------------------------------------------
# Your Supabase Project URL (e.g., https://yourproject.supabase.co)
SUPABASE_URL=https://your_project_ref.supabase.co

# Your Supabase Service Role API Key (service_role)
# Required to bypass Row Level Security (RLS) for server-side bot operations.
# Keep this extremely secure!
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Your Supabase Database Password (Optional, used for migrations / CLI setup)
SUPABASE_PASS=your_supabase_db_password_here

# ------------------------------------------------------------------------------
# 3. HTTP Keep-Alive Server Configuration
# ------------------------------------------------------------------------------
# The port the Express server will listen on. (Defaults to 3000 if not set)
# Useful for platforms like Render.com or Railway to keep the bot alive 24/7.
PORT=3000
