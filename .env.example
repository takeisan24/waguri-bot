# ==============================================================================
# Biến môi trường — Copy file này thành `.env` và điền giá trị thật.
# KHÔNG commit file `.env` lên git!
# ==============================================================================

# --- Discord ---
# Bot Token (Developer Portal -> app của bạn -> Bot -> Reset Token -> Copy)
DISCORD_TOKEN=your_bot_token_here
# Application ID (Developer Portal -> General Information -> Application ID)
CLIENT_ID=your_application_id_here

# (TÙY CHỌN — chỉ dùng khi DEV) ID server test để đăng ký lệnh TỨC THÌ.
# Để TRỐNG ở production -> lệnh sẽ đăng ký global.
GUILD_ID=

# Discord ID của owner (cho /eco-admin). Nhiều owner: ngăn cách bằng dấu phẩy.
OWNER_IDS=your_discord_user_id

# --- Supabase ---
# Project URL (Supabase -> Project Settings -> Data API -> Project URL)
SUPABASE_URL=https://your_project_ref.supabase.co
# Service Role key (Project Settings -> API Keys -> service_role).
# Bypass RLS cho bot server-side -> GIỮ TUYỆT MẬT, không dùng anon key.
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- AI persona Waguri (Google Gemini) ---
# API key Gemini (LẤY FREE tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# Model (mặc định gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# --- Top.gg (tùy chọn — chỉ cần sau khi đã list bot trên top.gg) ---
# Token để autopost số server + check vote cho /vote (Top.gg -> bot của bạn -> Webhooks/API).
# Để TRỐNG thì /vote chỉ hiện link, không tự phát thưởng; autopost bị bỏ qua.
# TOPGG_TOKEN=your_topgg_token_here
# Bí mật cho VOTE WEBHOOK (thưởng tức thì khi user vote). Webhook URL = https://<domain>/topgg/vote
#  - Webhook v0 (legacy): tự đặt 1 chuỗi ngẫu nhiên, dán y hệt vào ô Authorization trên Top.gg.
#  - Webhook v1 (mới): dùng secret Top.gg sinh sẵn dạng "whs_..." (bot tự xác thực HMAC SHA-256).
# Code nhận CẢ HAI kiểu, chỉ cần đặt đúng giá trị dashboard cho bạn vào đây.
# TOPGG_WEBHOOK_AUTH=whs_hoac_chuoi_bi_mat_cua_ban
# Cổng HTTP cho vote webhook + health check. Trên Wispbyte/Pterodactyl thường panel tự
# cấp qua SERVER_PORT; nếu không, đặt PORT = đúng cổng mà subdomain map vào.
# PORT=
# Đặt =1 để TẮT hẳn HTTP server vote webhook (vd khi host không mở cổng public).
# DISABLE_VOTE_SERVER=

# --- Bot-list khác (tùy chọn — autopost số server, mỗi cái no-op nếu thiếu token) ---
# discordbotlist.com -> bot của bạn -> Edit -> API Token
# DBL_TOKEN=
# discord.bots.gg -> bot của bạn -> Edit -> tạo API Token
# DBGG_TOKEN=

# --- Hỗ trợ & vận hành (tùy chọn) ---
# Link mời server hỗ trợ (cho /support, /about, lời chào).
# SUPPORT_INVITE=https://discord.gg/xxxxxxx
# Webhook kênh #logs để nhận lỗi runtime (error-log).
# LOG_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ID kênh RIÊNG để bot tự gửi backup DB mỗi 24h (file chứa dữ liệu -> kênh staff!).
# BACKUP_CHANNEL_ID=123456789012345678
# Tên nhà phát triển hiện trong /about (mặc định 'takei').
# BOT_CREATOR=takei
